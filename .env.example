# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fastapi_db

# Application database URL (used by FastAPI)
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/fastapi_db

# JWT secrets — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_random_32_char_hex
JWT_REFRESH_SECRET_KEY=replace_with_different_32_char_hex

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt work factor (use 4 in CI for speed, 12 in production)
BCRYPT_ROUNDS=12

# pgAdmin web UI credentials
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# Redis (optional — for JWT blacklisting on logout)
# REDIS_URL=redis://localhost:6379/0
